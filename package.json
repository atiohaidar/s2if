{
  "name": "s2if",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint scripts tests src/lib/data/content --ext .ts",
    "format:check": "prettier --check .",
    "test:tools": "tsx --test tests/scripts/**/*.test.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "sync:indexes": "tsx scripts/sync-indexes.ts",
    "create:topic": "tsx scripts/create-topic.ts",
    "check": "npm run validate:content && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.46.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.4",
    "@types/katex": "^0.16.8",
    "@types/prismjs": "^1.26.5",
    "katex": "^0.16.45",
    "lucide-svelte": "^1.0.1",
    "prismjs": "^1.30.0"
  }
}
